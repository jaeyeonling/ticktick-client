{
  "name": "ticktick-client",
  "version": "0.1.0",
  "description": "Unofficial TickTick API client for Node.js",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "docs:build": "typedoc"
  },
  "keywords": [
    "ticktick",
    "api",
    "client",
    "unofficial"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.18",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=22"
  }
}
