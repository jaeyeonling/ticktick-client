{
  "name": "ticktick-client",
  "version": "0.3.0",
  "description": "Unofficial TickTick API client for Node.js",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "ticktick-mcp": "./dist/mcp/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "docs:build": "typedoc"
  },
  "keywords": [
    "ticktick",
    "api",
    "client",
    "mcp",
    "model-context-protocol",
    "unofficial"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jaeyeonling/ticktick-client.git"
  },
  "homepage": "https://github.com/jaeyeonling/ticktick-client#readme",
  "bugs": {
    "url": "https://github.com/jaeyeonling/ticktick-client/issues"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "playwright": "^1.59.1",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.18",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  }
}
